#. Plugin Name of the plugin
#: easy-quicklinks.php
msgid "Easy Quicklinks"
msgstr "Easy Quicklinks"

#. Description of the plugin
#: easy-quicklinks.php
msgid "Adds support for top level quick link redirect in the post quick edit."
msgstr ""
"Lägger till stöd för snabblänksomdirigering på toppnivå i snabbredigeringen "
"av inlägg."

#: src/Admin/Ajax.php:20
msgid "Unauthorized."
msgstr "Ej behörig."

#: src/Admin/Ajax.php:34 src/Admin/QuickEditColumn.php:108
msgid "Only lowercase letters (a-z) and dashes (-) are allowed."
msgstr "Endast gemener (a-z) och bindestreck (-) är tillåtna."

#: src/Admin/Ajax.php:43
msgid "A top-level page already uses this slug."
msgstr "En sida på toppnivå använder redan detta alias."

#: src/Admin/Ajax.php:60
msgid "This quick link is already in use by another page."
msgstr "Den här snabblänken används redan av en annan sida."

#: src/Admin/Ajax.php:66 src/Admin/QuickEditColumn.php:110
msgid "Quick link is available."
msgstr "Snabblänken är tillgänglig."

#: src/Admin/NestedPagesIntegration.php:29 src/Admin/QuickEditColumn.php:22
#: src/Admin/QuickEditColumn.php:60
msgid "Quick Link"
msgstr "Snabblänk"

#: src/Admin/NestedPagesIntegration.php:30
msgctxt "Indicates a post has a quick link slug set in the quick edit"
msgid "quick link"
msgstr "snabblänk"

#: src/Admin/QuickEditColumn.php:67
msgid "e.g. testskolan"
msgstr "t.ex. testskolan"

#: src/Admin/QuickEditColumn.php:72
msgid ""
"Lowercase letters and dashes only. Creates a top-level redirect to this page."
msgstr ""
"Endast gemener och bindestreck. Skapar en omdirigering på toppnivå till "
"denna sida."

#: src/Admin/QuickEditColumn.php:109
msgid "This quick link is already in use."
msgstr "Den här snabblänken används redan."

#: src/Admin/QuickEditColumn.php:111
msgid "Checking availability"
msgstr "Kontrollerar tillgänglighet"
